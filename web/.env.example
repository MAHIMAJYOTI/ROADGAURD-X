# Copy to web/.env.local for local dev, or set in Vercel → Settings → Environment Variables.
# API base URL (no trailing slash).

# Local
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Production (Vercel) — required if your Render URL differs from the default in page.tsx
# NEXT_PUBLIC_API_URL=https://roadgaurd-x.onrender.com
